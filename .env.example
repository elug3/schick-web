SCHICK_API_BASE_URL=http://localhost:8080

# Optional overrides for split-service deployments:
# SCHICK_AUTH_API_BASE_URL=http://localhost:8080
# SCHICK_PRODUCT_API_BASE_URL=http://localhost:8081

# Optional HMAC JWT for server-side catalog reads (GET /api/products, GET /api/products/:id).
# Must be signed with the product service JWT_SECRET. Public bag search does not need this.
# SCHICK_PRODUCT_API_BEARER_TOKEN=
